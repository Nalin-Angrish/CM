# Database
POSTGRES_USER=cloudmgr
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=cloudmgr
DATABASE_URL=postgresql://cloudmgr:changeme_in_production@database:5432/cloudmgr

# JWT
JWT_SECRET=replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
MAX_RESOURCES_PER_USER=20

# Local LLM (Ollama)
LOCAL_LLM_MODEL=llama3.1:8b
OLLAMA_HOST=http://ollama:11434

# AWS
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=ap-south-1

# Services (internal Docker networking)
API_SERVER_URL=http://api-server:8000
LLM_SERVICE_URL=http://llm-service:8001
MCP_SERVER_URL=http://mcp-server:8002

# Redis
REDIS_URL=redis://redis:6379/0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
